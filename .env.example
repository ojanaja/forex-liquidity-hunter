# MetaTrader 5 Credentials
MT5_LOGIN=your_login_number
MT5_PASSWORD=your_password
MT5_SERVER=WeMasterTrade-Server

# Optional: Path to MetaTrader 5 terminal (if not in default location)
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Telegram Notifications
# Get BOT_TOKEN from @BotFather on Telegram
# Get CHAT_ID by sending a message to your bot then visiting:
#   https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
ENABLE_TELEGRAM=True
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
